# Supabase Postgres connection string
# Supabase 대시보드 → Project Settings → Database → Connection string → URI 탭
# Session mode (port 5432) 사용
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Admin 패널 접근 비밀번호 (로그인 폼에 입력)
ADMIN_PASSWORD=your-secure-password-here

# Admin 세션 쿠키에 저장되는 토큰 (랜덤 문자열)
# 생성: openssl rand -hex 32
ADMIN_TOKEN=your-random-secret-token-here

# Vercel Analytics (Vercel이 자동 설정, 로컬에선 불필요)
# NEXT_PUBLIC_VERCEL_URL=
